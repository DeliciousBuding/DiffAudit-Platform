{
  "name": "diffaudit-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Platform shell for DiffAudit frontend and API.",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "dev:api": "uv run --directory apps/api uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "test:api": "uv run --directory apps/api pytest",
    "lint:api": "uv run --directory apps/api ruff check .",
    "format:api": "uv run --directory apps/api ruff format ."
  }
}
