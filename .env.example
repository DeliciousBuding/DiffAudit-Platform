# DiffAudit Platform local configuration example.
# Copy needed values into an untracked .env.local or process-manager environment.

DIFFAUDIT_PLATFORM_URL=http://localhost:3000
DIFFAUDIT_API_BASE_URL=http://127.0.0.1:8780
DIFFAUDIT_DB_PATH=apps/web/data/diffaudit.db
DIFFAUDIT_DEMO_MODE=true
DIFFAUDIT_FORCE_DEMO_MODE=
DIFFAUDIT_PRIMARY_CONTRACT_KEY=

# Optional first local account bootstrap. Replace locally; do not commit real values.
DIFFAUDIT_SHARED_USERNAME=demo
DIFFAUDIT_SHARED_PASSWORD=replace-with-a-local-password

# Optional OAuth providers. Leave blank to hide provider buttons.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional external trial form URL.
DIFFAUDIT_TRIAL_FORM_URL=

# Go gateway settings.
DIFFAUDIT_PUBLIC_DATA_DIR=apps/api-go/data/public
DIFFAUDIT_RUNTIME_BASE_URL=
DIFFAUDIT_CORS_ALLOWED_ORIGINS=http://localhost:3000
