# Runtime environment values.
# Copy this file to deploy/runtime.env and keep the copy untracked.
# Leave OAuth provider values blank to hide their buttons.

DIFFAUDIT_PLATFORM_URL=http://localhost:3000
DIFFAUDIT_API_BASE_URL=http://api:8780
DIFFAUDIT_DB_PATH=/app/data/diffaudit.db
DIFFAUDIT_DEMO_MODE=true
DIFFAUDIT_FORCE_DEMO_MODE=
DIFFAUDIT_PRIMARY_CONTRACT_KEY=
DIFFAUDIT_CORS_ALLOWED_ORIGINS=http://localhost:3000
DIFFAUDIT_PUBLIC_DATA_DIR=/app/data/public
DIFFAUDIT_RUNTIME_BASE_URL=
DIFFAUDIT_TRIAL_FORM_URL=
DIFFAUDIT_BUILD_REVISION=local
DIFFAUDIT_BUILD_DATE=unknown

DIFFAUDIT_SHARED_USERNAME=demo
DIFFAUDIT_SHARED_PASSWORD=replace-with-a-local-password

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
