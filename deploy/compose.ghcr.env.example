# Docker Compose interpolation values for published GHCR images.
# Copy to deploy/.env, set DIFFAUDIT_IMAGE_TAG to an immutable sha-<short-sha> tag,
# and keep the copy untracked.

DIFFAUDIT_IMAGE_TAG=sha-0000000
DIFFAUDIT_WEB_IMAGE=ghcr.io/deliciousbuding/diffaudit-platform-web
DIFFAUDIT_API_IMAGE=ghcr.io/deliciousbuding/diffaudit-platform-api

# Bind locally by default. Put public TLS/proxy settings outside this repository.
DIFFAUDIT_WEB_BIND=127.0.0.1:3000
DIFFAUDIT_API_BIND=127.0.0.1:8780

# Host path containing sanitized public snapshot files.
DIFFAUDIT_PUBLIC_SNAPSHOT_DIR=../apps/api-go/data/public

DIFFAUDIT_VCS_REF=unknown
DIFFAUDIT_BUILD_DATE=unknown
DIFFAUDIT_INTERNAL_API_URL=http://api:8780
